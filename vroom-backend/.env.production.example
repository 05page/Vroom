APP_NAME=Vroom
APP_ENV=production
APP_KEY=                          # généré par: php artisan key:generate --show
APP_DEBUG=false
APP_URL=                          # URL Railway/Render ex: https://vroom-backend.railway.app

LOG_CHANNEL=stack
LOG_LEVEL=error

# ── Base de données (Neon PostgreSQL) ─────────────────────────────────────────
DB_CONNECTION=pgsql
DB_URL=                           # DATABASE_URL fourni par Neon (format: postgresql://...)

# ── Cache & Sessions ──────────────────────────────────────────────────────────
CACHE_STORE=database
SESSION_DRIVER=database
QUEUE_CONNECTION=database

# ── Broadcasting (Pusher) ─────────────────────────────────────────────────────
BROADCAST_CONNECTION=pusher
PUSHER_APP_ID=                    # depuis dashboard Pusher
PUSHER_APP_KEY=                   # depuis dashboard Pusher
PUSHER_APP_SECRET=                # depuis dashboard Pusher
PUSHER_APP_CLUSTER=mt1            # cluster choisi sur Pusher (ex: mt1, eu, ap1)
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=                 # depuis Google Cloud Console
GOOGLE_CLIENT_SECRET=             # depuis Google Cloud Console
GOOGLE_REDIRECT_URI=              # https://ton-backend.railway.app/api/auth/google/callback

# ── Google Gemini ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=                   # depuis Google AI Studio

# ── URLs croisées ─────────────────────────────────────────────────────────────
FRONTEND_URL=                     # URL Vercel ex: https://vroom.vercel.app

# ── Filesystem ────────────────────────────────────────────────────────────────
FILESYSTEM_DISK=local             # ou 's3' si tu migres vers un stockage cloud plus tard
